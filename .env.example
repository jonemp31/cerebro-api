# cerebro-api — variáveis de ambiente (copie para .env e ajuste)

# ── Postgres local ───────────────────────────────────────────────────────────
POSTGRES_USER=cerebro
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=cerebro
POSTGRES_PORT=5433                 # porta no host (5433 p/ não bater com a api-escala)

# ── Integração com a api-escala (Fase 1) ─────────────────────────────────────
# A api-escala rodando local no Docker Windows:
API_ESCALA_URL=http://host.docker.internal:3000

# Onde o cerebro escuta os webhooks (a api e o gateway apontam pra cá):
LISTEN_ADDR=:8090

# ── Gateway de pagamento (Fase 1 — preencher quando integrarmos) ──────────────
# PAYMENT_GATEWAY=
# PAYMENT_API_KEY=
# PAYMENT_WEBHOOK_SECRET=
